{
  "name": "prime-oracles-landing",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:css": "bunx @tailwindcss/cli -i ./src/input.css -o ./src/output.css --watch",
    "dev:server": "bun --hot src/index.ts",
    "dev": "bun run dev:css & bun run dev:server",
    "build:css": "bunx @tailwindcss/cli -i ./src/input.css -o ./src/output.css --minify",
    "build": "bun run build:css && bun build ./src/index.html --outdir=dist --sourcemap --target=browser --minify --define:process.env.NODE_ENV='\"production\"' --env='BUN_PUBLIC_*'",
    "start": "NODE_ENV=production bun src/index.ts"
  },
  "dependencies": {
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-slot": "^1.2.4",
    "@tailwindcss/cli": "^4.2.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "react": "^19",
    "react-dom": "^19",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1"
  },
  "devDependencies": {
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/bun": "latest"
  }
}
